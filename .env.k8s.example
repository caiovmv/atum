# Template de secrets para o cluster Kubernetes (namespace atum).
#
# USO:
#   1. Copie este arquivo: cp .env.k8s.example .env.k8s
#   2. Preencha todos os valores marcados com CHANGE_ME
#   3. Execute: .\scripts\k8s-reset-atum.ps1
#
# ATENÇÃO: .env.k8s contém credenciais reais — nunca commite esse arquivo.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=atum
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=atum
DATABASE_URL=postgresql://atum:CHANGE_ME@postgres.atum.svc.cluster.local:5432/atum

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis.atum.svc.cluster.local:6379/0

# ── APIs externas ─────────────────────────────────────────────────────────────
TMDB_API_KEY=CHANGE_ME
TMDB_READ_ACCESS_TOKEN=CHANGE_ME
LASTFM_API_KEY=CHANGE_ME

# ── Auth básica do Nginx (frontend) ──────────────────────────────────────────
BASIC_AUTH_USER=atum
BASIC_AUTH_PASS=CHANGE_ME

# ── JWT (Phase 2) ─────────────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 32
JWT_SECRET=CHANGE_ME

# ── Admin inicial (Phase 2) ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@loombeat.com
ADMIN_PASSWORD=CHANGE_ME

# ── Stripe (Phase 2) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# ── MinIO (secret separado: minio-secret) ────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME_min_8_chars

# ── Traefik Dashboard (opcional — kube-system) ────────────────────────────────
# Se preenchidos, o script cria o secret traefik-dashboard-auth em kube-system.
# Deixe em branco para pular.
TRAEFIK_DASHBOARD_USER=
TRAEFIK_DASHBOARD_PASSWORD=
