# Cliente de torrent: transmission | utorrent | folder
CLIENT_TYPE=transmission

# Transmission
TRANSMISSION_HOST=localhost
TRANSMISSION_PORT=9091
TRANSMISSION_USER=
TRANSMISSION_PASSWORD=

# uTorrent (Web UI)
UTORRENT_URL=http://localhost:8080
UTORRENT_USER=admin
UTORRENT_PASSWORD=

# Pasta para modo folder (FrostWire: pasta monitorada ou destino de magnets)
WATCH_FOLDER=./torrents

# Pasta de download (Transmission/utorrent ou --download-direct)
DOWNLOAD_DIR=

# 1337x: URL base (padrão: https://www.1377x.to). Para usar 1337x.to: X1337_BASE_URL=https://www.1337x.to
# X1337_BASE_URL=

# The Pirate Bay: domínio varia por região (padrão: https://tpb.party). Ex.: TPB_BASE_URL=https://thepiratebay.org
# TPB_BASE_URL=

# Outros indexadores (opcional; use --indexer no search)
# YTS (filmes): padrão https://yts.lt
# YTS_BASE_URL=https://yts.lt
# EZTV_BASE_URL=https://eztv.re
# NYAA_BASE_URL=https://nyaa.si
# LIMETORRENTS_BASE_URL=https://www.limetorrents.lol
# IPTORRENTS_BASE_URL=https://iptorrents.com  (tracker privado; auth não implementado)

# FlareSolverr (Docker): contorna Cloudflare/reCAPTCHA nos scripts scripts/scraping/*. Rode o serviço flaresolverr e use:
# FLARESOLVERR_URL=http://localhost:8191
# FLARESOLVERR_URL=

# Last.fm: API key opcional para resolver artista/álbum (obtenha em https://www.last.fm/api/account).
# Com LASTFM_API_KEY, use: dl-torrent search --album "The Wall" (resolve para "Pink Floyd - The Wall") ou dl-torrent resolve album "The Wall".
# LASTFM_API_KEY=

# TMDB (The Movie Database): capas para filmes e séries na interface web (https://www.themoviedb.org/settings/api).
# Use a API Key (v3) e o Read Access Token (v4) para buscas de poster.
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here

# Intervalo (segundos) entre atualizações de progresso do download no banco (padrão 1.0). Escritas são limitadas a 1/s por download.
# DOWNLOAD_PROGRESS_INTERVAL_SECONDS=1.0

# Pasta para cache de capas (artwork). Vazio = ~/.dl-torrent/covers
# COVERS_DIR=

# PostgreSQL (obrigatório para a API Web com persistência)
# DATABASE_URL=postgresql://dluser:dlpass@localhost:5432/dltorrent

# CORS: origens permitidas (separadas por vírgula). Padrão: * (todas).
# CORS_ORIGINS=http://localhost:5173,https://meu-dominio.com

# Basic auth entre frontend e API (quando exposto via tunnel). Nginx adiciona o header ao proxy; API valida.
# Quando definidos, apenas requisições com o header correto são aceitas.
# BASIC_AUTH_USER=atum
# BASIC_AUTH_PASS=senha_segura

# AI/LLM: configurados via Settings no frontend (ai_provider, ai_model, ai_api_key, ai_base_url).
# Fallback: ai_fallback_provider, ai_fallback_model, ai_fallback_api_key, ai_fallback_base_url.

# URL do Runner (usada pela API para proxiar operações de download)
# DOWNLOAD_RUNNER_URL=http://localhost:9092

# Concorrência dos daemons (opcional; valores são os defaults).
# SYNC_MAX_WORKERS: threads para ffprobe + capas no sync-daemon (padrão 8).
# ENRICHMENT_MAX_WORKERS: itens processados em paralelo no enrichment-daemon (padrão 5).
# SYNC_MAX_WORKERS=8
# ENRICHMENT_MAX_WORKERS=5
