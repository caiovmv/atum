# Cliente de torrent: transmission | utorrent | folder
CLIENT_TYPE=transmission

# Transmission
TRANSMISSION_HOST=localhost
TRANSMISSION_PORT=9091
TRANSMISSION_USER=
TRANSMISSION_PASSWORD=

# uTorrent (Web UI)
UTORRENT_URL=http://localhost:8080
UTORRENT_USER=admin
UTORRENT_PASSWORD=

# Pasta para modo folder (FrostWire: pasta monitorada ou destino de magnets)
WATCH_FOLDER=./torrents

# Pasta de download (Transmission/utorrent ou --download-direct)
DOWNLOAD_DIR=

# 1337x: URL base (padrão: https://www.1377x.to). Para usar 1337x.to: X1337_BASE_URL=https://www.1337x.to
# X1337_BASE_URL=

# The Pirate Bay: domínio varia por região (padrão: https://tpb.party). Ex.: TPB_BASE_URL=https://thepiratebay.org
# TPB_BASE_URL=

# TorrentGalaxy (padrão: https://torrentgalaxy.to). Domínio pode variar.
# TG_BASE_URL=

# Outros indexadores (opcional; use --indexer no search)
# YTS_BASE_URL=https://yts.mx
# EZTV_BASE_URL=https://eztv.re
# NYAA_BASE_URL=https://nyaa.si
# LIMETORRENTS_BASE_URL=https://www.limetorrents.lol
# TORLOCK_BASE_URL=https://www.torlock.com
# SPEEDTORRENT_BASE_URL=https://www.speedtorrent.re
# FITGIRL_BASE_URL=https://fitgirl-repacks.site
# RUTRACKER_BASE_URL=https://rutracker.org
# IPTORRENTS_BASE_URL=https://iptorrents.com  (tracker privado; auth não implementado)

# Last.fm: API key opcional para resolver artista/álbum (obtenha em https://www.last.fm/api/account).
# Com LASTFM_API_KEY, use: dl-torrent search --album "The Wall" (resolve para "Pink Floyd - The Wall") ou dl-torrent resolve album "The Wall".
# LASTFM_API_KEY=

# TMDB (The Movie Database): capas para filmes e séries na interface web (https://www.themoviedb.org/settings/api).
# Use a API Key (v3) e o Read Access Token (v4) para buscas de poster.
TMDB_API_KEY=0f5183ba98661fc5cdf7597d28669cc9
