# Copie para .env e ajuste. Usado com docker-compose.
# DATABASE_URL e REDIS_URL já estão no compose; sobrescreva aqui se quiser.

# TMDB (capas e detalhes para filmes/séries)
TMDB_API_KEY=

# Bibliotecas de mídia: pastas no host montadas como /library/music e /library/videos
# nos containers (api, runner, sync-daemon). O sync-daemon escaneia essas pastas para
# importar álbums/filmes já existentes na Minha Biblioteca. No compose os volumes
# padrão são D:\Library\Music e D:\Library\Videos; altere no docker-compose.yml
# se usar outros caminhos (ex.: Linux /home/user/Music).
# LIBRARY_MUSIC_PATH=/library/music
# LIBRARY_VIDEOS_PATH=/library/videos

# Indexadores: URLs base (opcional; padrões no código). Usados pela API e pelo indexers-daemon.
# YTS: use https://yts.lt (padrão no código).
# X1337_BASE_URL=  TPB_BASE_URL=  YTS_BASE_URL=https://yts.lt  EZTV_BASE_URL=  NYAA_BASE_URL=
# LIMETORRENTS_BASE_URL=  IPTORRENTS_BASE_URL=

# Opcional: sobrescrever URLs no compose
# DATABASE_URL=postgresql://dluser:dlpass@postgres:5432/dltorrent
# REDIS_URL=redis://redis:6379/0
# DOWNLOAD_RUNNER_URL=http://runner:9092
